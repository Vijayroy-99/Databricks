  "datasets": [
    {
      "name": "1eddf79a",
      "displayName": "fact",
      "config": {
        "version": "1.1",
        "source": "SELECT *,\r\n       CAST(is_late AS INT) * 100 AS late_pct_flag\r\nFROM olist.gold.fact_order_delivery",
        "dimensions": [
          {
            "expr": "source.*"
          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          }
        ]
      }
    },
    {
      "name": "c0ee9eb4",
      "displayName": "delivery_impact",
      "config": {
        "version": "1.1",
        "source": "SELECT\r\n  CASE\r\n    WHEN days_late <= -5 THEN 'Early (5+ days)'\r\n    WHEN days_late <   0 THEN 'Early (1-4 days)'\r\n    WHEN days_late =   0 THEN 'On time'\r\n    WHEN days_late <=  3 THEN 'Late (1-3 days)'\r\n    WHEN days_late <= 10 THEN 'Late (4-10 days)'\r\n    ELSE 'Late (10+ days)'\r\n  END AS delivery_bucket,\r\n  MIN(days_late) AS sort_key,\r\n  COUNT(*) AS orders,\r\n  ROUND(AVG(review_score), 2) AS avg_review\r\nFROM olist.gold.fact_order_delivery\r\nWHERE review_score IS NOT NULL\r\nGROUP BY 1",
        "dimensions": [
          {
            "expr": "source.*"
          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          }
        ]
      }
    },
    {
      "name": "fa6b7b37",
      "displayName": "monthly",
      "config": {
        "version": "1.1",
        "source": "SELECT * FROM olist.gold.agg_monthly_trend WHERE orders > 100",
        "dimensions": [
          {
            "expr": "source.*"
          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          }
        ]
      }
    },
